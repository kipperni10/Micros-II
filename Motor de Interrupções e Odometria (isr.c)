#include <xc.h>
#include "config.h"

// Variáveis voláteis compartilhadas com o main.c
extern volatile unsigned int rpm_atual;
extern volatile unsigned long odometria_pulsos;
extern volatile unsigned char duty_cycle;

// Contadores internos
volatile unsigned int pulsos_taco = 0;
volatile unsigned int cont_display = 0;
volatile unsigned int cont_base_tempo = 0;

// Flags de tempo (consumidas e zeradas no loop principal)
volatile unsigned char timer_50ms_flag = 0;
volatile unsigned char timer_05s_flag = 0;
volatile unsigned char timer_1s_flag = 0;

void __interrupt() ISR(void) {
    // 1. Interrupção Externa (RB0/INT) - Leitura do Tacômetro
    if (INTCONbits.INTF) {
        pulsos_taco++;         // O fan gera 2 pulsos por revolução [cite: 356]
        odometria_pulsos++;    // Acumula pulsos brutos para cálculo da distância (Pneu aro 15, 31cm) [cite: 234, 235]
        INTCONbits.INTF = 0;   // Limpa a flag de interrupção
    }

    // 2. Interrupção do Timer0 - Multiplexação e Scheduler (Tick de 1ms)
    if (INTCONbits.T0IF) {
        TMR0 = 131; // Recarga para aprox. 1ms (Ajustável conforme o prescaler)
        
        // Multiplexação do Display a ~60Hz [cite: 212]
        // 3 dígitos -> ~16ms total -> alterna a cada ~5ms
        cont_display++;
        if (cont_display >= 5) {
            alterna_digito_display();
            cont_display = 0;
        }

        // Base de tempo geral (Scheduler)
        cont_base_tempo++;
        
        if (cont_base_tempo % 50 == 0) {
            timer_50ms_flag = 1;  // Gatilho para ler temperatura (falha) [cite: 239]
        }
        
        if (cont_base_tempo % 500 == 0) {
            timer_05s_flag = 1;   // Gatilho para resposta dos pedais e anti-colisão (Opção A) [cite: 148, 149, 271]
        }
        
        if (cont_base_tempo >= 1000) {
            timer_1s_flag = 1;    // Gatilho para freio motor [cite: 153]
            
            // Calcula o RPM (1 segundo acumulado)
            rpm_atual = (pulsos_taco * 60) / 2; // RPM real = (Pulsos * 60s) / 2 pulsos_por_rev [cite: 356]
            pulsos_taco = 0;      // Reseta janela de leitura
            cont_base_tempo = 0;
        }

        INTCONbits.T0IF = 0; // Limpa a flag do Timer0
    }
}
